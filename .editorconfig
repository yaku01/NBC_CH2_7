# 이 파일이 프로젝트의 최상위 설정 파일임을 명시합니다. (상위 폴더 검색 중단)
root = true

# ------------------------------------------------------------------------------
# 1. 모든 파일에 적용되는 기본 설정
# ------------------------------------------------------------------------------
[*]
# [중요] 한글 주석 깨짐 및 컴파일 에러 방지 (BOM이 포함된 UTF-8 강제)
charset = utf-8-bom

# 윈도우(Windows) 표준 줄 바꿈 방식(CRLF) 사용
end_of_line = crlf

# 파일 저장 시 맨 마지막 줄에 빈 줄을 자동으로 하나 추가 (git 표준 준수)
insert_final_newline = true

# 코드 줄 끝에 불필요하게 붙은 공백을 저장 시 자동으로 제거
trim_trailing_whitespace = true

# 탭(Tab) 키를 누르면 탭 문자 대신 스페이스(공백)가 입력되도록 설정
indent_style = space

# 들여쓰기 간격을 스페이스 4칸으로 통일
indent_size = 4

# ------------------------------------------------------------------------------
# 2. C++ 소스(.cpp) 및 헤더(.h) 파일 전용 설정
# ------------------------------------------------------------------------------
[*.{cpp,h}]
# C++ 코드에서도 탭 대신 스페이스 사용을 확실하게 강제
indent_style = space

# C++ 들여쓰기 4칸 유지
indent_size = 4